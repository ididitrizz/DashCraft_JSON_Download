{
  "manifest_version": 3,
  "name": "DashCraft JSON Downloader",
  "version": "1.0",
  "permissions": ["activeTab", "downloads"],
"host_permissions": [
  "https://cdn.dashcraft.io/*"
],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
